# Telegram bot token. You may reuse the existing FaceForm BOT_TOKEN.
TELEGRAM_BOT_TOKEN=

# Public channel username, for example @faceform_ru, or numeric chat id.
TELEGRAM_CHANNEL_ID=@your_channel

# OpenAI API key used for web search and post generation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini

# Link under the post button.
FACEFORM_BOT_URL=https://t.me/your_faceform_bot?startapp

# Optional branding.
CHANNEL_NAME=FaceForm | Разбор внешности
CHANNEL_USERNAME=@your_channel

# A persistent Railway Volume should be mounted at /app/data.
STATE_FILE=/app/data/content-bot-state.json

# One run creates one post and exits. Railway Cron triggers the run.
# Recommended Railway cron for Moscow time 11:00 and 19:00:
# 0 8,16 * * *

# Safety / testing
DRY_RUN=false
SAMPLE_MODE=false
DISABLE_CARD=false

# Optional comma-separated list. Leave empty for broad web search.
SEARCH_ALLOWED_DOMAINS=
